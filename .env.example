PORT=5000
NODE_ENV=development
DB_URI=postgres://<username>:<password>@localhost:5432/<nama_database>
JWT_SECRET=               # Secret untuk JWT token
JWT_REFRESH_SECRET=       # Secret untuk refresh token
GOOGLE_CLIENT_ID=         # Google OAuth client ID
GOOGLE_CLIENT_SECRET=     # Google OAuth client secret
FRONTEND_URL=             # URL frontend untuk magic link redirect
SMTP_HOST=                # SMTP server (default: smtp.gmail.com)
SMTP_PORT=                # SMTP port (default: 587)
SMTP_USER=                # Email pengirim
SMTP_PASS=                # Password email / app password
INTERNAL_API_SECRET=